# ============================================================================
# CONFIGURACIÓN DE PRODUCCIÓN - FarmaGo Dashboard
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env en la raíz del proyecto
# 2. Reemplazar TU_IP_SERVIDOR con la IP real del servidor (ej: 192.168.1.100)
# 3. Si usas dominio, reemplazar con el dominio (ej: dashboard.farmago.com)
# 4. Mantener las credenciales de VTEX actuales
# 5. Para el frontend, crear .env.production con VITE_API_URL
#
# ============================================================================

# VTEX API Credentials (mantener las actuales)
VTEX_ACCOUNT=medifarmape
VTEX_APP_KEY=vtexappkey-medifarmape-TISBGF
VTEX_APP_TOKEN=UTSFLETYSPKLCZKJFMCVXMSDMKOQEZVKYCDQWCNZVQYMWBPIZHOVPXHIWAHLUOCIESAGXGYOGMINTBXPOSMRDIEOOOUPMIUQXEHFKPZINLUNRWTKUGRLAZXMSXKJRBSB

# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration
# IMPORTANTE: Reemplazar TU_IP_SERVIDOR con la IP real
# Si usas puerto 80 (Nginx), usar: http://TU_IP_SERVIDOR
# Si usas puerto 5173 directo, usar: http://TU_IP_SERVIDOR:5173
# Si usas HTTPS, usar: https://TU_DOMINIO
CORS_ORIGINS=http://TU_IP_SERVIDOR,http://TU_IP_SERVIDOR:5173,http://TU_IP_SERVIDOR:3000

# Redis Configuration (recomendado para producción)
REDIS_URL=redis://localhost:6379

# ============================================================================
# FRONTEND BUILD CONFIGURATION
# ============================================================================
# 
# Crear archivo .env.production en la raíz con:
# VITE_API_URL=http://TU_IP_SERVIDOR:3001
#
# Luego ejecutar: npm run build
#
# ============================================================================
