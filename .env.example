# VTEX API Credentials
VTEX_ACCOUNT=your_account_name
VTEX_APP_KEY=your_app_key
VTEX_APP_TOKEN=your_app_token

# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration (comma-separated URLs)
# IMPORTANTE: Agregar las URLs desde donde se accederá al dashboard
# Ejemplo: CORS_ORIGINS=http://192.168.1.100:80,http://192.168.1.100:5173,https://dashboard.farmago.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Redis Configuration (opcional - usa memoria si no está disponible)
# Recomendado para producción
REDIS_URL=redis://localhost:6379

# Frontend API URL (solo para desarrollo local)
# En producción, crear archivo .env.production con:
# VITE_API_URL=http://TU_IP_SERVIDOR:3001
VITE_API_URL=http://localhost:3001

# Authentication Credentials (Frontend)
# IMPORTANTE: Cambiar estas credenciales en producción
# Usuario y contraseña para acceder al dashboard
VITE_AUTH_USERNAME=admin
VITE_AUTH_PASSWORD=farmago2026
